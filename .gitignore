# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.local

# ── Environment variables — NEVER commit real secrets ─────────────────────────
.env
# .env.example is safe to commit — it has no real values

# ── ChromaDB persistent storage ───────────────────────────────────────────────
# This folder grows with every document you process.
# It is local state, not source code.
data/
data/chroma_db/

# ── HuggingFace model cache ───────────────────────────────────────────────────
# Models are downloaded automatically on first run.
# Never commit them — they are 90MB–750MB each.
.cache/
~/.cache/huggingface/
models/

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml        # if you ever add Streamlit secrets

# ── pytest ────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Uploaded test PDFs ────────────────────────────────────────────────────────
# Don't accidentally commit patient records or legal documents
*.pdf
uploads/
test_docs/